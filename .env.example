# .env.example
# ============================================
# SmartGym API - Variables de Entorno
# ============================================
# INSTRUCCIONES:
# 1. Copia este archivo como .env
# 2. Cambia los valores por los tuyos
# 3. NUNCA subas .env a Git
# ============================================

# --- Base de Datos (PostgreSQL con Docker) ---
POSTGRES_USER=random_user 
POSTGRES_PASSWORD=random_pass 
POSTGRES_DB=random_db
POSTGRES_HOST=db    # Para trabajar desde Docker, sino, se cambia
POSTGRES_PORT=5432  # Puerto comun al trabajar con postgre, lo podemos cambiar
DATABASE_URL=postgresql://smartgym_user:smartgym_pass@localhost:5432/smartgym_db

# Entorno
ENVIRONMENT=development

# --- Seguridad JWT ---
# Genera una clave en la terminal con: python -c "import secrets; print(secrets.token_hex(32))"
# o con: py -c "import secrets; print(secrets.token_hex(32))" 
SECRET_KEY=genera-una-clave-secreta-aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Puerto de la API ---
PORT=8000   # Lo puedes cambiar 